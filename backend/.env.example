# --- Backend Makalmy Stock ---

# Base de données PostgreSQL (Render)
# Laisser vide pour utiliser SQLite en local
DATABASE_URL=

# Secret JWT (choisir un mot de passe aléatoire)
JWT_SECRET=votre-secret-jwt-ici

# URL du frontend (pour CORS en production)
FRONTEND_URL=https://votre-app.vercel.app

# Port du serveur (Render le définit automatiquement)
PORT=3001
